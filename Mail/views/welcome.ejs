<!DOCTYPE html>
<html>

<body style="font-family:Arial;background:#f4f4f4;margin:0;padding:0;">

    <div
        style="max-width:600px;margin:20px auto;background:#ffffff;padding:20px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);">

        <div
            style="background:#28a745;color:white;padding:20px;text-align:center;font-size:22px;border-radius:6px 6px 0 0;">
            Welcome to ServEaso 🎉
        </div>

        <div style="padding:20px;font-size:16px;color:#333;">
            <p>Dear <strong>
                    <%= userName %>
                </strong>,</p>

            <p>Thank you for registering with ServEaso.</p>

            <p>We’re excited to serve you!</p>

            <p>Need help? Call us at <strong>
                    <%= phoneNumber %>
                </strong></p>

            <p>Best Regards,<br><strong>ServEaso Team</strong></p>
        </div>

        <hr>

        <p style="text-align:center;font-size:12px;color:#777;">
            © 2026 ServEaso. All rights reserved.
        </p>

    </div>

</body>

</html>